apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: cohesity-web
  namespace: cohesity-ve
  labels:
    app: cohesity
spec:
  to:
    kind: Service
    name: cohesity-web-ui
    weight: 100
  port:
    targetPort: https
  tls:
    termination: passthrough
    insecureEdgeTerminationPolicy: Redirect
  wildcardPolicy: None